PORT=3000
NODE_ENV=production

# Safety
AUTOMATION_ENGINE_ENABLED=true
TRACKING_SYNC_ENABLED=true
SHADOW_MODE=true
RUN_ON_START=false
MANUAL_TRIGGER_TOKEN=replace-with-a-long-random-secret

# Schedule (UTC). Every 5 minutes:
TRACKING_SYNC_CRON=*/5 * * * *
TRACKING_SYNC_CONCURRENCY=3

# Airtable
AIRTABLE_TOKEN=pat...
AIRTABLE_MAIN_BASE_ID=appHoMBqKDPnVfWJY
AIRTABLE_UOL_TABLE_ID=tblFdnvcyttZyGx0b
AIRTABLE_SELLERS_TABLE_ID=tblHXvGz5aRaw93jB
AIRTABLE_INVENTORY_UNITS_TABLE_ID=tblt1aavfuJgspt8x
AIRTABLE_EXTERNAL_BASE_ID=appY9ZV7HJMYQbLUA
AIRTABLE_EXTERNAL_SALES_TABLE_ID=tbloLumvktySBlOvM

# AfterShip - rotate the key exposed in the Make blueprint
AFTERSHIP_API_KEY=replace-me
AFTERSHIP_API_VERSION=2026-01

# Existing outbound notifications
ITEM_SHIPPED_WEBHOOK_URL=https://airtable-discord-updates.onrender.com
DELIVERED_DISCORD_WEBHOOK_URL=replace-with-rotated-discord-webhook
